import csv

with open('COMPRAS_supermercado.csv', mode='r', encoding='utf-8') as archivo:
    lector = csv.reader(archivo)
    next(lector) #Saltamos encabezado
    #Convertimos a lista para poder navegar por indices con while
    filas = list(lector)

i = 0 #El indice de la fila actual 
n = len(filas) #Cantidad de filas totales en el archivo


CANSUC = 0 #Contador de sucursales 
TOTALIMP = 0 #Importe total de TODAS las sucursales #Ambos son totales globales, no de una sucursal
while i < n: #WHILE PARA SABER CUANDO CORTAR EN GENERAL
    sucursal_actual = filas[i][0]
    print(f"SUCURSAL {sucursal_actual}:")
    MYPROD = ""
    MYIMPOR = 0
    MNPROD = ""
    MNIMPOR = float("inf") #Es infinito 
    TOTSUC = 0 
    while i < n and filas[i][0] == sucursal_actual: #WHILE SUCURSAL
        producto_actual = filas[i][1]
        TOTPES = 0 #Total en pesos del producto vendido
        TOTUNI = 0 #Cantidad del producto vendido 
        while i < n and filas[i][0] == sucursal_actual and filas[i][1] == producto_actual: #WHILE PRODUCTO
            TOTUNI += int(filas[i][4]) #Total comprado en unidades
            TOTPES += int(filas[i][4]) * float(filas[i][5]) #Total comprado en pesos
            i += 1 #Avanzamos a la siguiente fila
        #Ahora queremos chequear maximo y minimo
        if TOTPES > MYIMPOR: #MAXIMO
            MYPROD = producto_actual 
            MYIMPOR = TOTPES
            
        if TOTPES < MNIMPOR: #MINIMO
            MNPROD = producto_actual
            MNIMPOR = TOTPES
        #Ahora que estamos por cambiar de producto, mostramos lo que se nos pidio para cada producto
        print(f"-Producto: {producto_actual}")
        print(f"  Unidades compradas: {TOTUNI} | Importe total comprado: ${TOTPES}")
        

        #TOTSUC = cantidad de productos vendidos por sucursal
        TOTSUC += TOTUNI
        TOTALIMP += TOTPES #Sumo cada importe de cada producto al total de los importes de todas las sucursales 

    
    CANSUC += 1 #Cuenta cuántas sucursales procesaste.
    #Ahora que estamos por cambiar de sucursal, mostramos lo que se nos pidio para cada sucursal
    print(f"   Total unidades en sucursal: {TOTSUC}")
    print(f"   Mayor compra: {MYPROD} -> ${MYIMPOR}")
    print(f"   Menor compra: {MNPROD} -> ${MNIMPOR}")
    print("-------------------------------------------------")

print(f"Total de sucursales del supermercado: {CANSUC}")
print(f"Compra total de todas las sucursales en conjunto: ${TOTALIMP}")

